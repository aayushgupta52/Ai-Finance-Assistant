# Frontend build-time config (Vite). Only VITE_-prefixed vars are exposed.

# API base URL used by the browser.
# - Leave unset (or '/api') when the frontend and backend share an origin,
#   i.e. nginx / a reverse proxy forwards /api to the backend.
# - Set to the backend's absolute URL for a split deploy, e.g.
#   VITE_API_BASE_URL=https://api.fintrack.in/api
VITE_API_BASE_URL=/api

# Dev-only: override the Vite dev-server proxy target (defaults to
# http://localhost:5000). Not used in production builds.
VITE_DEV_API_TARGET=http://localhost:5000
