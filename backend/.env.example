# Server
NODE_ENV=development                 # set to "production" when deploying
PORT=5000
# Set to "true" to disable node-cron scheduled jobs (monthly reports, alerts).
# Useful in CI/tests or when a separate worker owns the schedule.
DISABLE_CRON=false
# Frontend origin(s) allowed by CORS. Comma-separate to allow more than one,
# e.g. https://fintrack.in,https://www.fintrack.in
FRONTEND_URL=http://localhost:5173

# Database (Neon PostgreSQL)
# DATABASE_URL = pooled connection (used by the app at runtime).
# DIRECT_URL   = direct/non-pooled connection (used by Prisma migrations).
#   With no separate pooled URL, set DIRECT_URL equal to DATABASE_URL.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Railway / local)
REDIS_URL=redis://default:password@127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=replace_with_64_char_random_secret
JWT_REFRESH_SECRET=replace_with_another_64_char_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Groq AI (Get free at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@fintrack.in

# Monitoring
SENTRY_DSN=

# Admin
ADMIN_SECRET_KEY=your_admin_key_for_initial_setup

# WhatsApp bot (Baileys). Set to true, then scan the terminal QR on first boot.
# Users are linked by matching their WhatsApp number to User.phone.
#
# Keep this FALSE on serverless/managed hosts (Railway, Render, Vercel): it needs
# terminal access to scan the QR, and a PERSISTENT disk for the session at
# ./auth_info_baileys — otherwise it re-prompts for QR on every restart.
# Enable only on a long-running self-hosted server (or the docker-compose stack,
# which persists the session in the `wa_auth` volume).
WHATSAPP_ENABLED=false
